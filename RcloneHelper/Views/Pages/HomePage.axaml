<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RcloneHelper.Core.Pages"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="RcloneHelper.Views.Pages.HomePage"
             x:DataType="vm:HomePageViewModel">
    <Design.DataContext>
        <vm:HomePageViewModel />
    </Design.DataContext>
    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="15,8" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Margin" Value="5" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Margin" Value="5" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" Padding="15">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="挂载管理" FontSize="20" FontWeight="Bold" 
                           Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="添加挂载" Command="{Binding AddMountCommand}" 
                        Background="{DynamicResource AccentBrush}" 
                        Foreground="{DynamicResource AccentForegroundBrush}" Padding="12,6" />
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="10">
            <!-- 挂载列表 -->
            <Grid Margin="5">
                <Grid RowDefinitions="Auto,*">
                    <!-- 标题栏 -->
                    <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" Padding="10,8">
                        <Grid ColumnDefinitions="50,*,80,80,100">
                            <TextBlock Grid.Column="0" Text="状态" FontWeight="Bold" Foreground="{DynamicResource AccentForegroundBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="名称" FontWeight="Bold" Foreground="{DynamicResource AccentForegroundBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="类型" FontWeight="Bold" Foreground="{DynamicResource AccentForegroundBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="盘符" FontWeight="Bold" Foreground="{DynamicResource AccentForegroundBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="操作" FontWeight="Bold" Foreground="{DynamicResource AccentForegroundBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- 挂载列表 -->
                    <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <ListBox ItemsSource="{Binding AllMounts}" SelectedItem="{Binding SelectedMount}" 
                                 Background="Transparent" BorderThickness="0">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                </Style>
                                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="{DynamicResource ListItemHoverBrush}" />
                                </Style>
                                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                    <Setter Property="Background" Value="{DynamicResource ListItemSelectedBrush}" />
                                </Style>
                                <!-- 选中状态下的文字颜色覆盖 -->
                                <Style Selector="ListBoxItem:selected TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource ListItemSelectedForegroundBrush}" />
                                </Style>
                                <Style Selector="ListBoxItem:selected Path">
                                    <Setter Property="Fill" Value="{DynamicResource ListItemSelectedForegroundBrush}" />
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,8">
                                        <Grid ColumnDefinitions="50,*,80,80,100">
                                            <!-- 状态 -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                                                <Ellipse Width="10" Height="10" Fill="{DynamicResource SuccessBrush}" 
                                                         IsVisible="{Binding IsMounted}" />
                                                <Ellipse Width="10" Height="10" Fill="{DynamicResource ForegroundMutedBrush}" 
                                                         IsVisible="{Binding !IsMounted}" />
                                            </StackPanel>

                                            <!-- 名称 -->
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" 
                       VerticalAlignment="Center" Foreground="{DynamicResource ForegroundBrush}" />

                                            <!-- 类型 -->
                                            <TextBlock Grid.Column="2" Text="{Binding Type}" VerticalAlignment="Center" 
                       Foreground="{DynamicResource ForegroundMutedBrush}" />

                                            <!-- 盘符 -->
                                            <TextBlock Grid.Column="3" Text="{Binding LocalDrive}" VerticalAlignment="Center" 
                       FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" />

                                            <!-- 操作按钮 -->
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                                                <!-- 播放按钮 - 未挂载时显示 -->
                                                <Button IsVisible="{Binding !IsMounted}" Background="Transparent" Padding="8,3" Margin="0" Cursor="Hand"
                                                        Command="{Binding $parent[UserControl].DataContext.MountItemCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Path Width="12" Height="12" Stretch="Uniform" 
                                                          Fill="{DynamicResource ForegroundBrush}"
                                                          Data="{DynamicResource IconPlay}" />
                                                </Button>
                                                <!-- 暂停按钮 - 已挂载时显示 -->
                                                <Button IsVisible="{Binding IsMounted}" Background="Transparent" Padding="8,3" Margin="0" Cursor="Hand"
                                                        Command="{Binding $parent[UserControl].DataContext.UnmountItemCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Path Width="12" Height="12" Stretch="Uniform" 
                                                          Fill="{DynamicResource ForegroundBrush}"
                                                          Data="{DynamicResource IconPause}" />
                                                </Button>
                                                <!-- 编辑按钮 -->
                                                <Button Background="Transparent" Padding="8,3" Margin="0" Cursor="Hand"
                                                        Command="{Binding $parent[UserControl].DataContext.EditItemCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Path Width="12" Height="12" Stretch="Uniform" 
                                                          Fill="{DynamicResource ForegroundBrush}"
                                                          Data="{DynamicResource IconEdit}" />
                                                </Button>
                                                <!-- 删除按钮 -->
                                                <Button Background="Transparent" Padding="8,3" Margin="0" Cursor="Hand"
                                                        Command="{Binding $parent[UserControl].DataContext.DeleteItemCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Path Width="12" Height="12" Stretch="Uniform" 
                                                          Fill="{DynamicResource ForegroundBrush}"
                                                          Data="{DynamicResource IconDelete}" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

<!-- 编辑面板 -->
        <Border Grid.Row="0" Grid.RowSpan="2" Background="#80000000" IsVisible="{Binding IsEditing}">
            <Border Background="{DynamicResource SurfaceBrush}" Width="520" Padding="20" 
                    VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="5">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="编辑挂载" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"
                               Foreground="{DynamicResource ForegroundBrush}" />

                    <ScrollViewer Grid.Row="1" MaxHeight="450">
                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                            <!-- 基础字段 -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="名称:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditingMount.Name}" Watermark="输入名称" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="类型:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}" />
                            <ComboBox Grid.Row="1" Grid.Column="1" SelectedItem="{Binding EditingMount.Type}" HorizontalAlignment="Stretch">
                                <x:String>webdav</x:String>
                                <x:String>ftp</x:String>
                                <x:String>sftp</x:String>
                                <x:String>s3</x:String>
                            </ComboBox>

                            <!-- WebDAV/FTP/SFTP 通用字段：主机地址 -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="主机地址:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       IsVisible="{Binding EditingMount.IsNetworkStorageType}" />
                            <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="Auto,*,Auto,Auto" 
                                  IsVisible="{Binding EditingMount.IsWebDavType}">
                                <ComboBox Grid.Column="0" SelectedItem="{Binding EditingMount.Protocol}" 
                                          ItemsSource="{Binding ProtocolOptions}" MinWidth="75" Margin="5,5,5,5" />
                                <TextBox Grid.Column="1" Text="{Binding EditingMount.Host}" Watermark="example.com" Margin="0,5" />
                                <TextBlock Grid.Column="2" Text=":" VerticalAlignment="Center" Margin="0"
                                           Foreground="{DynamicResource ForegroundMutedBrush}" />
                                <TextBox Grid.Column="3" Text="{Binding EditingMount.Port}" Watermark="443" Width="65" Margin="5,5,5,5" />
                            </Grid>
                            <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto,Auto" 
                                  IsVisible="{Binding EditingMount.IsFtpType}">
                                <TextBox Grid.Column="0" Text="{Binding EditingMount.Host}" Watermark="ftp.example.com" Margin="0" />
                                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="5,0"
                                           Foreground="{DynamicResource ForegroundMutedBrush}" />
                                <TextBox Grid.Column="2" Text="{Binding EditingMount.Port}" Watermark="21" Width="60" Margin="0" />
                            </Grid>
                            <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto,Auto" 
                                  IsVisible="{Binding EditingMount.IsSftpType}">
                                <TextBox Grid.Column="0" Text="{Binding EditingMount.Host}" Watermark="sftp.example.com" Margin="0" />
                                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="5,0"
                                           Foreground="{DynamicResource ForegroundMutedBrush}" />
                                <TextBox Grid.Column="2" Text="{Binding EditingMount.Port}" Watermark="22" Width="60" Margin="0" />
                            </Grid>

                            <!-- WebDAV/FTP/SFTP 路径 -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="路径:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       IsVisible="{Binding EditingMount.IsNetworkStorageType}" />
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EditingMount.Path}" 
                                     Watermark="路径 (可选)"
                                     IsVisible="{Binding EditingMount.IsNetworkStorageType}" />

                            <!-- WebDAV/FTP/SFTP 用户名 -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="用户名:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       IsVisible="{Binding EditingMount.IsNetworkStorageType}" />
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditingMount.User}" Watermark="可选"
                                     IsVisible="{Binding EditingMount.IsNetworkStorageType}" />

                            <!-- WebDAV/FTP/SFTP 密码 -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="密码:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       IsVisible="{Binding EditingMount.IsNetworkStorageType}" />
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EditingMount.Password}" PasswordChar="*" Watermark="可选"
                                     IsVisible="{Binding EditingMount.IsNetworkStorageType}" />

                            <!-- WebDAV 服务商 -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="服务商:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       IsVisible="{Binding EditingMount.IsWebDavType}" />
                            <ComboBox Grid.Row="6" Grid.Column="1" SelectedItem="{Binding EditingMount.Vendor}" HorizontalAlignment="Stretch"
                                      IsVisible="{Binding EditingMount.IsWebDavType}">
                                <x:String>other</x:String>
                                <x:String>owncloud</x:String>
                                <x:String>nextcloud</x:String>
                                <x:String>sharepoint</x:String>
                                <x:String>fastmail</x:String>
                            </ComboBox>

                            <!-- S3 配置 -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="服务商:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       IsVisible="{Binding EditingMount.IsS3Type}" />
                            <ComboBox Grid.Row="2" Grid.Column="1" SelectedItem="{Binding EditingMount.S3Provider}" HorizontalAlignment="Stretch"
                                      IsVisible="{Binding EditingMount.IsS3Type}">
                                <x:String>AWS</x:String>
                                <x:String>Alibaba</x:String>
                                <x:String>TencentCOS</x:String>
                                <x:String>Google</x:String>
                                <x:String>Other</x:String>
                            </ComboBox>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Access Key:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       IsVisible="{Binding EditingMount.IsS3Type}" />
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EditingMount.AccessKeyId}" Watermark="Access Key ID"
                                     IsVisible="{Binding EditingMount.IsS3Type}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Secret Key:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       IsVisible="{Binding EditingMount.IsS3Type}" />
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditingMount.SecretAccessKey}" PasswordChar="*" Watermark="Secret Access Key"
                                     IsVisible="{Binding EditingMount.IsS3Type}" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="区域:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       IsVisible="{Binding EditingMount.IsS3Type}" />
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EditingMount.Region}" Watermark="如: us-east-1, ap-northeast-1"
                                     IsVisible="{Binding EditingMount.IsS3Type}" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Endpoint:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       IsVisible="{Binding EditingMount.IsS3Type}" />
                            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding EditingMount.Endpoint}" Watermark="可选，用于兼容S3的服务"
                                     IsVisible="{Binding EditingMount.IsS3Type}" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Bucket:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       IsVisible="{Binding EditingMount.IsS3Type}" />
                            <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding EditingMount.RemotePath}" Watermark="bucket-name 或 bucket/path"
                                     IsVisible="{Binding EditingMount.IsS3Type}" />

                            <!-- 其他类型 URL 输入 -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="URL:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       IsVisible="{Binding EditingMount.UseUrlInput}" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditingMount.Url}" Watermark="https://example.com/path"
                                     IsVisible="{Binding EditingMount.UseUrlInput}" />

<!-- 通用字段：本地盘符 -->
                            <TextBlock Grid.Row="10" Grid.Column="0" Text="本地盘符:" VerticalAlignment="Center" Margin="5"
                                       Foreground="{DynamicResource ForegroundBrush}" />
                            <ComboBox Grid.Row="10" Grid.Column="1" SelectedItem="{Binding EditingMount.LocalDrive}" HorizontalAlignment="Stretch">
                                <x:String>Z:</x:String>
                                <x:String>Y:</x:String>
                                <x:String>X:</x:String>
                                <x:String>W:</x:String>
                                <x:String>V:</x:String>
                                <x:String>U:</x:String>
                                <x:String>T:</x:String>
                                <x:String>S:</x:String>
                                <x:String>R:</x:String>
                                <x:String>Q:</x:String>
                                <x:String>P:</x:String>
                                <x:String>O:</x:String>
                                <x:String>N:</x:String>
                                <x:String>M:</x:String>
                                <x:String>L:</x:String>
                                <x:String>K:</x:String>
                                <x:String>J:</x:String>
                                <x:String>I:</x:String>
                                <x:String>H:</x:String>
                                <x:String>G:</x:String>
                                <x:String>F:</x:String>
                                <x:String>E:</x:String>
                                <x:String>D:</x:String>
                            </ComboBox>

                            <CheckBox Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" Content="网络驱动器模式" 
                                      IsChecked="{Binding EditingMount.UseNetworkMode}" Margin="5"
                                      Foreground="{DynamicResource ForegroundBrush}" />
                            <TextBlock Grid.Row="12" Grid.Column="1" Text="(显示为：名称 (\\rclone))" 
                                       FontSize="11" Foreground="{DynamicResource ForegroundMutedBrush}"
                                       Margin="130,8,0,0" IsVisible="{Binding EditingMount.UseNetworkMode}" />

                            <CheckBox Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="2" Content="启动时自动挂载" 
                                      IsChecked="{Binding EditingMount.AutoMountOnStart}" Margin="5"
                                      Foreground="{DynamicResource ForegroundBrush}" />
                        </Grid>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="保存" Command="{Binding SaveMountCommand}" 
                                Background="{DynamicResource AccentBrush}"
                                Foreground="{DynamicResource AccentForegroundBrush}" />
                        <Button Content="取消" Command="{Binding CancelEditCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>