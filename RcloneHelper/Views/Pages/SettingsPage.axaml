<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RcloneHelper.Core.Pages"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="RcloneHelper.Views.Pages.SettingsPage"
             x:DataType="vm:SettingsPageViewModel">
    <Design.DataContext>
        <vm:SettingsPageViewModel />
    </Design.DataContext>
    <Grid RowDefinitions="Auto,*">
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" Padding="15">
            <TextBlock Text="配置" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" />
        </Border>

        <!-- 配置内容 -->
        <ScrollViewer Grid.Row="1" Margin="20,0,0,0">
            <StackPanel Spacing="20">
                <TextBlock Text="系统设置" FontWeight="Bold" FontSize="16"
                           Foreground="{DynamicResource ForegroundBrush}" />

                <Border Background="{DynamicResource CardBrush}" Padding="15" CornerRadius="5">
                    <StackPanel Spacing="15">
                        <CheckBox Content="开机启动" IsChecked="{Binding AutoStartEnabled}"
                                  Foreground="{DynamicResource ForegroundBrush}" />
                        <CheckBox Content="静默启动" IsChecked="{Binding StartSilently}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  IsEnabled="{Binding AutoStartEnabled}" />
                        <TextBlock Text="启用后，开机启动时程序将最小化到系统托盘"
                                   Foreground="{DynamicResource ForegroundMutedBrush}" FontSize="12"
                                   IsVisible="{Binding AutoStartEnabled}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="代理设置" FontWeight="Bold" FontSize="16" Margin="0,10,0,0"
                           Foreground="{DynamicResource ForegroundBrush}" />

                <Border Background="{DynamicResource CardBrush}" Padding="15" CornerRadius="5">
                    <StackPanel Spacing="15">
                        <CheckBox Content="启用代理" IsChecked="{Binding ProxyEnabled}"
                                  Foreground="{DynamicResource ForegroundBrush}" />
                        <TextBlock Text="启用后，所有 rclone 挂载操作都将通过指定的代理服务器访问网络"
                                   Foreground="{DynamicResource ForegroundMutedBrush}" FontSize="12"
                                   IsVisible="{Binding ProxyEnabled}" />

                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" IsVisible="{Binding ProxyEnabled}">
                            <TextBlock Grid.Column="0" Text="代理服务器："
                                       Foreground="{DynamicResource ForegroundMutedBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <ComboBox Grid.Column="1" SelectedItem="{Binding ProxyProtocol}"
                                      ItemsSource="{Binding ProxyProtocolOptions}" MinWidth="80"
                                      VerticalAlignment="Center" Margin="0,5" />
                            <TextBox Grid.Column="2" Text="{Binding ProxyHost}"
                                     Watermark="127.0.0.1" VerticalAlignment="Center" Margin="5,5" />
                            <TextBlock Grid.Column="3" Text=":" VerticalAlignment="Center"
                                       Foreground="{DynamicResource ForegroundMutedBrush}" Margin="0,0,0,0" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding ProxyEnabled}">
                            <TextBlock Grid.Column="0" Text="端口号："
                                       Foreground="{DynamicResource ForegroundMutedBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBox Grid.Column="1" Text="{Binding ProxyPort}"
                                     Watermark="7890" Width="100" HorizontalAlignment="Left"
                                     VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock Text="常用端口: HTTP代理 80/8080, HTTPS代理 443, SOCKS5代理 1080/7890"
                                   Foreground="{DynamicResource ForegroundMutedBrush}"
                                   FontSize="11" TextWrapping="Wrap"
                                   IsVisible="{Binding ProxyEnabled}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="数据存储" FontWeight="Bold" FontSize="16" Margin="0,10,0,0"
                           Foreground="{DynamicResource ForegroundBrush}" />

                <Border Background="{DynamicResource CardBrush}" Padding="15" CornerRadius="5">
                    <StackPanel Spacing="10">
                        <!-- 程序数据目录 -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="程序数据："
                                       Foreground="{DynamicResource ForegroundMutedBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Grid.Column="1" Text="{Binding AppDataPath}"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                            <Button Grid.Column="2" Content="打开"
                                    Command="{Binding OpenAppDataFolderCommand}"
                                    Padding="10,5" Margin="10,0,0,0"
                                    Background="{DynamicResource ButtonBrush}"
                                    Foreground="{DynamicResource ButtonForegroundBrush}" />
                        </Grid>

                        <!-- 程序所在位置 -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="程序位置："
                                       Foreground="{DynamicResource ForegroundMutedBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Grid.Column="1" Text="{Binding AppLocation}"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                            <Button Grid.Column="2" Content="打开"
                                    Command="{Binding OpenAppLocationFolderCommand}"
                                    Padding="10,5" Margin="10,0,0,0"
                                    Background="{DynamicResource ButtonBrush}"
                                    Foreground="{DynamicResource ButtonForegroundBrush}" />
                        </Grid>

                        <!-- 分隔线 -->
                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,5" />

                        <!-- 配置导入导出 -->
                        <TextBlock Text="配置备份与恢复"
                                   Foreground="{DynamicResource ForegroundMutedBrush}"
                                   FontSize="12" Margin="0,5,0,0" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="导出配置"
                                    Command="{Binding ExportConfigCommand}"
                                    Padding="15,8"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="{DynamicResource AccentForegroundBrush}" />
                            <Button Content="导入配置"
                                    Command="{Binding ImportConfigCommand}"
                                    Padding="15,8"
                                    Background="{DynamicResource ButtonBrush}"
                                    Foreground="{DynamicResource ButtonForegroundBrush}" />
                        </StackPanel>
                        <TextBlock Text="导出会将所有挂载配置保存为 JSON 文件&#x0a;导入会从配置目录读取备份文件（跳过已存在的挂载）"
                                   Foreground="{DynamicResource ForegroundMutedBrush}"
                                   FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock Text="关于" FontWeight="Bold" FontSize="16" Margin="0,10,0,0"
                           Foreground="{DynamicResource ForegroundBrush}" />

                <Border Background="{DynamicResource CardBrush}" Padding="15" CornerRadius="5" Margin="0,0,0,20">
                    <StackPanel Spacing="5">
                        <TextBlock Text="{Binding AppVersionLabel}"
                                   Foreground="{DynamicResource ForegroundBrush}" />
                        <TextBlock Text="网络存储挂载管理工具"
                                   Foreground="{DynamicResource ForegroundMutedBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>