<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RcloneHelper.Core.Pages"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="RcloneHelper.Views.Pages.SettingsPage"
             x:DataType="vm:SettingsPageViewModel">
    <Design.DataContext>
        <vm:SettingsPageViewModel />
    </Design.DataContext>
    <Grid RowDefinitions="Auto,*">
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" Padding="15">
            <TextBlock Text="配置" FontSize="20" FontWeight="Bold" 
                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" />
        </Border>

        <!-- 配置内容 -->
        <StackPanel Grid.Row="1" Margin="20" Spacing="20">
            <TextBlock Text="系统设置" FontWeight="Bold" FontSize="16" 
                       Foreground="{DynamicResource ForegroundBrush}" />

            <Border Background="{DynamicResource CardBrush}" Padding="15" CornerRadius="5">
                <StackPanel Spacing="15">
                    <CheckBox Content="开机启动" IsChecked="{Binding AutoStartEnabled}"
                              Foreground="{DynamicResource ForegroundBrush}" />
                    <CheckBox Content="启动时自动挂载所有存储" IsChecked="{Binding AutoMountOnStart}"
                              Foreground="{DynamicResource ForegroundBrush}" />
                </StackPanel>
            </Border>

            <TextBlock Text="关于" FontWeight="Bold" FontSize="16" Margin="0,10,0,0"
                       Foreground="{DynamicResource ForegroundBrush}" />

            <Border Background="{DynamicResource CardBrush}" Padding="15" CornerRadius="5">
                <StackPanel Spacing="5">
                    <TextBlock Text="Rclone Helper v1.0.0" 
                               Foreground="{DynamicResource ForegroundBrush}" />
                    <TextBlock Text="网络存储挂载管理工具" 
                               Foreground="{DynamicResource ForegroundMutedBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>