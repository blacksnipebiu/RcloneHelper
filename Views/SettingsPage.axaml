<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="RcloneHelper.Views.SettingsPage">
    <Grid RowDefinitions="Auto,*">
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#2d2d2d" Padding="15">
            <TextBlock Text="配置" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
        </Border>

        <!-- 配置内容 -->
        <StackPanel Grid.Row="1" Margin="20" Spacing="20">
            <TextBlock Text="系统设置" FontWeight="Bold" FontSize="16" />

            <Border Background="White" Padding="15" CornerRadius="5">
                <StackPanel Spacing="15">
                    <CheckBox Content="开机启动" IsChecked="{Binding AutoStartEnabled}" Command="{Binding ToggleAutoStartCommand}" />
                    <CheckBox Content="启动时自动挂载所有存储" IsChecked="{Binding AutoMountOnStart}" Command="{Binding SaveSettingsCommand}" />
                </StackPanel>
            </Border>

            <TextBlock Text="关于" FontWeight="Bold" FontSize="16" Margin="0,10,0,0" />

            <Border Background="White" Padding="15" CornerRadius="5">
                <StackPanel Spacing="5">
                    <TextBlock Text="Rclone Helper v1.0.0" />
                    <TextBlock Text="网络存储挂载管理工具" Foreground="#666" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
