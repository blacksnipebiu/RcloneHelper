<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="RcloneHelper.Views.HomePage">
    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="15,8" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Margin" Value="5" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Margin" Value="5" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto,Auto">
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#2d2d2d" Padding="15">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="挂载管理" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                <CheckBox Grid.Column="1" Content="开机启动" Foreground="White" IsChecked="{Binding AutoStartEnabled}" Command="{Binding ToggleAutoStartCommand}" />
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" ColumnDefinitions="*,300" Margin="10">
            <!-- 左侧：挂载列表 -->
            <Grid Grid.Column="0" Margin="5">
                <Grid RowDefinitions="Auto,*">
                    <!-- 标题栏 -->
                    <Border Grid.Row="0" Background="#4CAF50" Padding="10">
                        <Grid ColumnDefinitions="*,80,80,*,Auto">
                            <TextBlock Grid.Column="0" Text="名称" FontWeight="Bold" Foreground="White" />
                            <TextBlock Grid.Column="1" Text="类型" FontWeight="Bold" Foreground="White" />
                            <TextBlock Grid.Column="2" Text="盘符" FontWeight="Bold" Foreground="White" />
                            <TextBlock Grid.Column="3" Text="远程路径" FontWeight="Bold" Foreground="White" />
                            <TextBlock Grid.Column="4" Text="状态" FontWeight="Bold" Foreground="White" />
                        </Grid>
                    </Border>

                    <!-- 挂载列表 -->
                    <Border Grid.Row="1" BorderBrush="#ddd" BorderThickness="1">
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding AllMounts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#eee" BorderThickness="0,0,0,1" Padding="10,8">
                                            <Grid ColumnDefinitions="*,80,80,*,Auto">
                                                <!-- 名称 -->
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center" />

                                                <!-- 类型 -->
                                                <TextBlock Grid.Column="1" Text="{Binding Type}" VerticalAlignment="Center" Foreground="#666" />

                                                <!-- 盘符 -->
                                                <TextBlock Grid.Column="2" Text="{Binding LocalDrive}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#4CAF50" />

                                                <!-- 远程路径 -->
                                                <TextBlock Grid.Column="3" Text="{Binding RemotePath}" VerticalAlignment="Center" Foreground="#666" />

                                                <!-- 状态 -->
                                                <TextBlock Grid.Column="4" Text="已挂载" VerticalAlignment="Center" Foreground="#4CAF50" FontWeight="Bold" 
                                                           IsVisible="{Binding IsMounted}" />
                                                <TextBlock Grid.Column="4" Text="未挂载" VerticalAlignment="Center" Foreground="#999" 
                                                           IsVisible="{Binding !IsMounted}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <!-- 右侧：操作面板 -->
            <StackPanel Grid.Column="1" Margin="10" Spacing="10">
                <TextBlock Text="操作" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />

                <Button Content="添加挂载" Command="{Binding AddMountCommand}" HorizontalAlignment="Stretch" />
                <Button Content="编辑选中" Command="{Binding EditMountCommand}" IsEnabled="{Binding SelectedMount, Converter={x:Static ObjectConverters.IsNotNull}}" HorizontalAlignment="Stretch" />
                <Button Content="删除选中" Command="{Binding DeleteMountCommand}" IsEnabled="{Binding SelectedMount, Converter={x:Static ObjectConverters.IsNotNull}}" HorizontalAlignment="Stretch" Background="#f44336" Foreground="White" />

                <Border Background="#f5f5f5" Padding="10" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="挂载/卸载操作" FontWeight="Bold" Margin="0,0,0,10" />
                        <Grid ColumnDefinitions="*,*" Margin="0,0,0,5">
                            <Button Grid.Column="0" Content="挂载选中" Command="{Binding MountSelectedCommand}" Background="#4CAF50" Foreground="White" Margin="0" />
                            <Button Grid.Column="1" Content="卸载选中" Command="{Binding UnmountSelectedCommand}" Background="#f44336" Foreground="White" Margin="5,0,0,0" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*">
                            <Button Grid.Column="0" Content="挂载全部" Command="{Binding MountAllAsyncCommand}" Background="#2196F3" Foreground="White" Margin="0" />
                            <Button Grid.Column="1" Content="卸载全部" Command="{Binding UnmountAllAsyncCommand}" Background="#FF9800" Foreground="White" Margin="5,0,0,0" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#f0f0f0" Padding="10" Margin="0,10,0,0" IsVisible="{Binding SelectedMount, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel>
                        <TextBlock Text="选中挂载详情" FontWeight="Bold" Margin="0,0,0,10" />
                        <TextBlock Text="{Binding SelectedMount.Name, StringFormat='名称: {0}'}" />
                        <TextBlock Text="{Binding SelectedMount.Url, StringFormat='URL: {0}'}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SelectedMount.Type, StringFormat='类型: {0}'}" />
                        <TextBlock Text="{Binding SelectedMount.User, StringFormat='用户: {0}'}" />
                        <TextBlock Text="{Binding SelectedMount.LocalDrive, StringFormat='本地盘符: {0}'}" />
                        <TextBlock Text="{Binding SelectedMount.Status, StringFormat='状态: {0}'}" />
                        <CheckBox Content="启动时自动挂载" IsChecked="{Binding SelectedMount.AutoMountOnStart}" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="#f0f0f0" Padding="10">
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>

        <!-- 编辑面板 -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="#80000000" IsVisible="{Binding IsEditing}">
            <Border Background="White" Width="500" Padding="20" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="5">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="编辑挂载" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" />

                    <Grid Grid.Row="1" ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="名称:" VerticalAlignment="Center" Margin="5" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditingMount.Name}" Watermark="输入名称" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="类型:" VerticalAlignment="Center" Margin="5" />
                        <ComboBox Grid.Row="1" Grid.Column="1" SelectedItem="{Binding EditingMount.Type}" HorizontalAlignment="Stretch">
                            <x:String>webdav</x:String>
                            <x:String>ftp</x:String>
                            <x:String>sftp</x:String>
                            <x:String>s3</x:String>
                        </ComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="URL:" VerticalAlignment="Center" Margin="5" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditingMount.Url}" Watermark="https://example.com/dav" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="用户名:" VerticalAlignment="Center" Margin="5" />
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EditingMount.User}" Watermark="可选" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="密码:" VerticalAlignment="Center" Margin="5" />
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditingMount.Password}" PasswordChar="*" Watermark="可选" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="WebDAV 服务商:" VerticalAlignment="Center" Margin="5" />
                        <ComboBox Grid.Row="5" Grid.Column="1" SelectedItem="{Binding EditingMount.Vendor}" HorizontalAlignment="Stretch">
                            <x:String>other</x:String>
                            <x:String>owncloud</x:String>
                            <x:String>nextcloud</x:String>
                            <x:String>sharepoint</x:String>
                            <x:String>fastmail</x:String>
                        </ComboBox>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="远程路径:" VerticalAlignment="Center" Margin="5" />
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding EditingMount.RemotePath}" Watermark="例如: /path/to/folder (可选)" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="本地盘符:" VerticalAlignment="Center" Margin="5" />
                        <ComboBox Grid.Row="7" Grid.Column="1" SelectedItem="{Binding EditingMount.LocalDrive}" HorizontalAlignment="Stretch">
                            <x:String>Z:</x:String>
                            <x:String>Y:</x:String>
                            <x:String>X:</x:String>
                            <x:String>W:</x:String>
                            <x:String>V:</x:String>
                            <x:String>U:</x:String>
                            <x:String>T:</x:String>
                            <x:String>S:</x:String>
                            <x:String>R:</x:String>
                            <x:String>Q:</x:String>
                            <x:String>P:</x:String>
                            <x:String>O:</x:String>
                            <x:String>N:</x:String>
                            <x:String>M:</x:String>
                            <x:String>L:</x:String>
                            <x:String>K:</x:String>
                            <x:String>J:</x:String>
                            <x:String>I:</x:String>
                            <x:String>H:</x:String>
                            <x:String>G:</x:String>
                            <x:String>F:</x:String>
                            <x:String>E:</x:String>
                            <x:String>D:</x:String>
                        </ComboBox>

                        <CheckBox Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Content="启动时自动挂载" IsChecked="{Binding EditingMount.AutoMountOnStart}" Margin="5" />
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="保存" Command="{Binding SaveMountCommand}" />
                        <Button Content="取消" Command="{Binding CancelEditCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>